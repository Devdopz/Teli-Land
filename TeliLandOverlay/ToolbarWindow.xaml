<Window x:Class="TeliLandOverlay.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TeliLand Tools"
        Width="238"
        Height="64"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#2A2A2A" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ToolbarButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="Background" Value="Transparent" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ToolbarButtonBorder" Property="Background" Value="#EEF4FB" />
                                <Setter TargetName="ToolbarButtonBorder" Property="BorderBrush" Value="#D8E3EF" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True" />
                                    <Condition Property="Background" Value="Transparent" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ToolbarButtonBorder" Property="Background" Value="#E4EDF7" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorOptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ColorOptionButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorOptionButtonBorder" Property="Background" Value="#2AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DEE5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#5B6470" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseToolbarButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseToolbarButtonBorder" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseToolbarButtonBorder" Property="Background" Value="#E5EDF6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent"
          MouseEnter="DragSurface_OnMouseEnter"
          MouseLeave="DragSurface_OnMouseLeave"
          MouseLeftButtonDown="DragSurface_OnMouseLeftButtonDown"
          MouseLeftButtonUp="DragSurface_OnMouseLeftButtonUp"
          MouseMove="DragSurface_OnMouseMove">
        <Border Margin="0,12,0,0"
                CornerRadius="12"
                Background="#FCFCFC"
                BorderBrush="#D8DEE5"
                BorderThickness="1"
                Padding="8"
                Cursor="SizeAll">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="0"
                                  Opacity="0.18"
                                  Color="#000000" />
            </Border.Effect>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,16,0">
                <Button x:Name="PencilToolButton"
                        Width="40"
                        Click="PencilToolButton_OnClick"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Pencil">
                    <Viewbox Width="18"
                             Height="18">
                        <Path Data="M 3 12 L 11.8 3.2 L 13.9 5.3 L 5.1 14.1 L 2.4 14.6 Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent" />
                    </Viewbox>
                </Button>

                <Button x:Name="ColorPickerButton"
                        Width="48"
                        Margin="8,0,0,0"
                        Click="ColorPickerButton_OnClick"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Pencil color">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Border x:Name="CurrentColorSwatch"
                                Width="16"
                                Height="16"
                                CornerRadius="8"
                                BorderBrush="#1A1A1A"
                                BorderThickness="1" />
                        <Path Margin="6,0,0,0"
                              VerticalAlignment="Center"
                              Data="M 2 4 L 6 8 L 10 4"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" />
                    </StackPanel>
                </Button>

                <Button x:Name="SizePickerButton"
                        Width="64"
                        Margin="8,0,0,0"
                        Click="SizePickerButton_OnClick"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Pencil size">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="SizeValueText"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="12"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   VerticalAlignment="Center"
                                   Text="3 px" />
                        <Path Margin="6,0,0,0"
                              VerticalAlignment="Center"
                              Data="M 2 4 L 6 8 L 10 4"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Popup x:Name="ColorMenuPopup"
               AllowsTransparency="True"
               Placement="Top"
               PlacementTarget="{Binding ElementName=ColorPickerButton}"
               HorizontalOffset="-6"
               VerticalOffset="-6"
               PopupAnimation="Fade"
               StaysOpen="False"
               Closed="ToolPopup_OnClosed">
            <Border Background="#1F1F1F"
                    CornerRadius="16"
                    Padding="12"
                    MouseEnter="PopupSurface_OnMouseEnter"
                    MouseLeave="PopupSurface_OnMouseLeave">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="0"
                                      Opacity="0.28"
                                      Color="#000000" />
                </Border.Effect>

                <StackPanel>
                    <TextBlock Margin="0,0,0,10"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="13"
                               Foreground="White"
                               Text="Pencil Color" />
                    <WrapPanel x:Name="ColorPalettePanel">
                        <Button Tag="#1D2733"
                                Click="ColorOptionButton_OnClick"
                                Style="{StaticResource ColorOptionButtonStyle}">
                            <Border Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#1D2733" />
                        </Button>
                        <Button Tag="#2A9CFF"
                                Click="ColorOptionButton_OnClick"
                                Style="{StaticResource ColorOptionButtonStyle}">
                            <Border Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#2A9CFF" />
                        </Button>
                        <Button Tag="#FF6B35"
                                Click="ColorOptionButton_OnClick"
                                Style="{StaticResource ColorOptionButtonStyle}">
                            <Border Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#FF6B35" />
                        </Button>
                        <Button Tag="#22C55E"
                                Click="ColorOptionButton_OnClick"
                                Style="{StaticResource ColorOptionButtonStyle}">
                            <Border Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#22C55E" />
                        </Button>
                        <Button Tag="#FACC15"
                                Click="ColorOptionButton_OnClick"
                                Style="{StaticResource ColorOptionButtonStyle}">
                            <Border Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#FACC15" />
                        </Button>
                        <Button Tag="#EF4444"
                                Margin="0"
                                Click="ColorOptionButton_OnClick"
                                Style="{StaticResource ColorOptionButtonStyle}">
                            <Border Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#EF4444" />
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="SizeMenuPopup"
               AllowsTransparency="True"
               Placement="Top"
               PlacementTarget="{Binding ElementName=SizePickerButton}"
               HorizontalOffset="-54"
               VerticalOffset="-6"
               PopupAnimation="Fade"
               StaysOpen="False"
               Closed="ToolPopup_OnClosed">
            <Border Background="#1F1F1F"
                    CornerRadius="16"
                    Padding="12"
                    MouseEnter="PopupSurface_OnMouseEnter"
                    MouseLeave="PopupSurface_OnMouseLeave">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="0"
                                      Opacity="0.28"
                                      Color="#000000" />
                </Border.Effect>

                <StackPanel Width="176">
                    <TextBlock Margin="0,0,0,10"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="13"
                               Foreground="White"
                               Text="Pencil Size" />
                    <Grid Margin="0,0,0,10">
                        <Border Height="24"
                                CornerRadius="12"
                                Background="#16FFFFFF"
                                BorderBrush="#30FFFFFF"
                                BorderThickness="1">
                            <Grid>
                                <Rectangle x:Name="SizePreviewLine"
                                           Width="96"
                                           Height="3"
                                           RadiusX="1.5"
                                           RadiusY="1.5"
                                           Fill="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                    <Slider x:Name="SizeSlider"
                            Minimum="1.5"
                            Maximum="12"
                            Value="3"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            ValueChanged="SizeSlider_OnValueChanged" />
                </StackPanel>
            </Border>
        </Popup>

        <Button Style="{StaticResource CloseToolbarButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,0,6,0"
                Click="CloseToolbarButton_OnClick"
                ToolTip="Close toolbar"
                Content="X" />
    </Grid>
</Window>
