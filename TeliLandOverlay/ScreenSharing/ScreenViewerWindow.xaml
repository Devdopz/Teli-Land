<Window x:Class="TeliLandOverlay.ScreenViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Live Screen Viewer"
        Width="1120"
        Height="720"
        MinWidth="860"
        MinHeight="540"
        Background="#101214"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="18,18,18,12"
                Padding="18,14"
                CornerRadius="18"
                Background="#171B1F"
                BorderBrush="#26303A"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="ViewerTitleText"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="20"
                               Foreground="White"
                               Text="Connected Screen" />
                    <TextBlock x:Name="ViewerStatusText"
                               Margin="0,4,0,0"
                               FontFamily="Bahnschrift"
                               FontSize="13"
                               Foreground="#A7B4C2"
                               Text="Waiting for screen sharing to start..." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="10,5"
                        CornerRadius="999"
                        Background="#1639FF14"
                        BorderBrush="#3039FF14"
                        BorderThickness="1">
                    <TextBlock x:Name="ConnectionBadgeText"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="12"
                               Foreground="#8CFF7A"
                               Text="CONNECTED" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="18,0,18,18"
                CornerRadius="24"
                Background="#0D0F11"
                BorderBrush="#20252B"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Image x:Name="ViewerImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <Border x:Name="PlaceholderOverlay"
                        Background="#12000000">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock FontFamily="Bahnschrift SemiBold"
                                   FontSize="24"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Text="Live screen will appear here" />
                        <TextBlock Margin="0,8,0,0"
                                   FontFamily="Bahnschrift"
                                   FontSize="14"
                                   Foreground="#A4B0BC"
                                   HorizontalAlignment="Center"
                                   Text="Once the connected peer starts sharing, the stream will show here." />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
