<Window x:Class="TeliLandOverlay.ScreenShareHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TeliLand Screen Share"
        Width="920"
        Height="620"
        MinWidth="860"
        MinHeight="560"
        Background="#101214"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="#0E130C" />
            <Setter Property="Background" Value="#8CFF7A" />
            <Setter Property="BorderBrush" Value="#8CFF7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#1B2026" />
            <Setter Property="BorderBrush" Value="#2A323D" />
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#171B1F" />
            <Setter Property="BorderBrush" Value="#2A323D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PeerListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="PeerListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="PeerCardBorder"
                                Background="#14181C"
                                BorderBrush="#20272E"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14,12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PeerCardBorder" Property="BorderBrush" Value="#305164" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PeerCardBorder" Property="Background" Value="#142126" />
                                <Setter TargetName="PeerCardBorder" Property="BorderBrush" Value="#4D8CFF7A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22,18"
                CornerRadius="24"
                Background="#171B1F"
                BorderBrush="#242D37"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift SemiBold"
                               FontSize="28"
                               Foreground="White"
                               Text="TeliLand Screen Share" />
                    <TextBlock Margin="0,8,0,0"
                               FontFamily="Bahnschrift"
                               FontSize="14"
                               Foreground="#A7B4C2"
                               Text="Devices on the same WiFi appear here. Pick one, send a request, and live screen sharing starts only after the other person approves." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,7"
                        CornerRadius="999"
                        Background="#1539FF14"
                        BorderBrush="#3039FF14"
                        BorderThickness="1">
                    <TextBlock x:Name="TopStatusBadgeText"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="12"
                               Foreground="#8CFF7A"
                               Text="READY" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.35*" />
            </Grid.ColumnDefinitions>

            <Border Padding="22"
                    CornerRadius="22"
                    Background="#171B1F"
                    BorderBrush="#242D37"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="White"
                               Text="Receive Requests" />
                    <TextBlock Margin="0,6,0,0"
                               FontFamily="Bahnschrift"
                               FontSize="14"
                               Foreground="#A7B4C2"
                               Text="This PC stays visible on the same WiFi. When someone requests access, you will get an approval popup." />

                    <Border Margin="0,22,0,18"
                            Padding="16"
                            CornerRadius="18"
                            Background="#111519"
                            BorderBrush="#20272E"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontFamily="Bahnschrift SemiBold"
                                       FontSize="13"
                                       Foreground="#7B8B9A"
                                       Text="THIS DEVICE" />
                            <TextBlock x:Name="LocalDeviceNameText"
                                       Margin="0,8,0,0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="20"
                                       Foreground="White"
                                       Text="This PC" />
                            <TextBlock x:Name="HostStatusText"
                                       Margin="0,6,0,0"
                                       FontFamily="Bahnschrift"
                                       FontSize="14"
                                       Foreground="#A7B4C2"
                                       Text="Preparing WiFi visibility..." />
                            <TextBlock x:Name="LocalDeviceAddressText"
                                       Margin="0,10,0,0"
                                       FontFamily="Bahnschrift"
                                       FontSize="13"
                                       Foreground="#7B8B9A"
                                       Text="WiFi address: detecting..." />
                        </StackPanel>
                    </Border>

                    <StackPanel>
                        <Button x:Name="AvailabilityButton"
                                Click="AvailabilityButton_OnClick"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Content="Pause Incoming Requests" />
                        <Button x:Name="StartSharingButton"
                                Margin="0,12,0,0"
                                Click="StartSharingButton_OnClick"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="Start Screen Sharing" />
                        <Button x:Name="StopSharingButton"
                                Margin="0,12,0,0"
                                Click="StopSharingButton_OnClick"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="Stop Screen Sharing" />
                        <Button x:Name="DisconnectButton"
                                Margin="0,12,0,0"
                                Click="DisconnectButton_OnClick"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="Disconnect Peer" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="22"
                    CornerRadius="22"
                    Background="#171B1F"
                    BorderBrush="#242D37"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontFamily="Bahnschrift SemiBold"
                                   FontSize="22"
                                   Foreground="White"
                                   Text="Join a Peer" />
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="Bahnschrift"
                                   FontSize="14"
                                   Foreground="#A7B4C2"
                                   Text="Choose any running device on the same WiFi, send a request, and wait for the other person to approve it." />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Padding="14"
                            CornerRadius="18"
                            Background="#111519"
                            BorderBrush="#20272E"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="13"
                                               Foreground="#7B8B9A"
                                               Text="DISCOVERED PEERS" />
                                <TextBlock x:Name="DiscoveryStatusText"
                                           Margin="0,6,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="14"
                                           Foreground="#A7B4C2"
                                           Text="Scanning the same WiFi for running TeliLand devices..." />
                                </StackPanel>

                                <Button x:Name="RefreshPeersButton"
                                        Grid.Column="1"
                                        Width="124"
                                        Margin="18,0,0,0"
                                        Click="RefreshPeersButton_OnClick"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Content="Refresh List" />
                            </Grid>

                            <Grid Grid.Row="1"
                                  Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="156" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="ManualAddressTextBox"
                                         KeyDown="ManualAddressTextBox_OnKeyDown"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         ToolTip="Enter the host PC WiFi IP, for example 192.168.1.15"
                                         Text="192.168.1.15" />

                                <Button x:Name="ManualConnectButton"
                                        Grid.Column="2"
                                        Click="ManualConnectButton_OnClick"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Content="Connect by IP" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2"
                          Margin="0,18,0,0">
                        <ListBox x:Name="PeerListBox"
                                 SelectionChanged="PeerListBox_OnSelectionChanged"
                                 Style="{StaticResource PeerListBoxStyle}"
                                 ItemContainerStyle="{StaticResource PeerListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock FontFamily="Bahnschrift SemiBold"
                                                       FontSize="17"
                                                       Foreground="White"
                                                       Text="{Binding DeviceName}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontFamily="Bahnschrift"
                                                       FontSize="13"
                                                       Foreground="#9FB0BF"
                                                       Text="{Binding HostAddress}" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Padding="10,5"
                                                CornerRadius="999"
                                                Background="#1539FF14"
                                                BorderBrush="#3039FF14"
                                                BorderThickness="1">
                                            <TextBlock FontFamily="Bahnschrift SemiBold"
                                                       FontSize="11"
                                                       Foreground="#8CFF7A"
                                                       Text="AVAILABLE" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border x:Name="EmptyPeersState"
                                CornerRadius="18"
                                Background="#101316"
                                BorderBrush="#20272E"
                                BorderThickness="1"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock FontFamily="Bahnschrift SemiBold"
                                           FontSize="22"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           Text="No peers found yet" />
                                <TextBlock Margin="0,8,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="14"
                                           Foreground="#A7B4C2"
                                           HorizontalAlignment="Center"
                                           Text="Ask the other person to open TeliLand on the same WiFi first." />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Button x:Name="ConnectButton"
                            Grid.Row="3"
                            Margin="0,18,0,0"
                            Click="ConnectButton_OnClick"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Content="Send Request to Selected Device" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Padding="14,12"
                CornerRadius="16"
                Background="#14181C"
                BorderBrush="#20272E"
                BorderThickness="1">
            <TextBlock x:Name="FooterStatusText"
                       FontFamily="Bahnschrift"
                       FontSize="13.5"
                       Foreground="#A7B4C2"
                       Text="Tip: select a device, send a request, and sharing begins only after the other person approves." />
        </Border>
    </Grid>
</Window>
