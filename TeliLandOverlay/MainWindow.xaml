<Window x:Class="TeliLandOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TeliLand Overlay"
        Width="96"
        Height="96"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="SecondaryCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="#F6F6F6" />
            <Setter Property="BorderBrush" Value="#22000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="8.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.18"
                                                  Color="#000000" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit Overlay" Click="ExitOverlay_OnClick" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid>
        <Popup x:Name="ActionMenuPopup"
               AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=MainBadgeHost}"
               Placement="Custom"
               StaysOpen="True"
               PopupAnimation="Fade">
            <Border Background="Transparent"
                    Padding="8"
                    MouseEnter="ActionMenu_OnMouseEnter"
                    MouseLeave="ActionMenu_OnMouseLeave">
                <Grid>
                    <StackPanel x:Name="VerticalMenuPanel">
                        <Button Style="{StaticResource SecondaryCircleButtonStyle}"
                                Content="START"
                                ToolTip="Start" />
                        <Button Style="{StaticResource SecondaryCircleButtonStyle}"
                                Content="TOOLS"
                                Click="ToolsButton_OnClick"
                                ToolTip="Tools" />
                        <Button Style="{StaticResource SecondaryCircleButtonStyle}"
                                Content="MENU"
                                Margin="0"
                                ToolTip="Menu" />
                    </StackPanel>

                    <StackPanel x:Name="HorizontalMenuPanel"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                        <Button Style="{StaticResource SecondaryCircleButtonStyle}"
                                Content="START"
                                Margin="0,0,10,0"
                                ToolTip="Start" />
                        <Button Style="{StaticResource SecondaryCircleButtonStyle}"
                                Content="TOOLS"
                                Margin="0,0,10,0"
                                Click="ToolsButton_OnClick"
                                ToolTip="Tools" />
                        <Button Style="{StaticResource SecondaryCircleButtonStyle}"
                                Content="MENU"
                                Margin="0"
                                ToolTip="Menu" />
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>

        <Border x:Name="MainBadgeHost"
                Width="82"
                Height="82"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#33FFFFFF"
                BorderBrush="#2A000000"
                BorderThickness="1"
                CornerRadius="41"
                Cursor="Hand"
                RenderTransformOrigin="0.5,0.5"
                MouseEnter="MainBadge_OnMouseEnter"
                MouseLeave="MainBadge_OnMouseLeave"
                MouseLeftButtonDown="MainBadge_OnMouseLeftButtonDown"
                MouseMove="MainBadge_OnMouseMove"
                MouseLeftButtonUp="MainBadge_OnMouseLeftButtonUp"
                ToolTip="Click to toggle menu. Drag to move. Right-click to exit.">
            <Border.RenderTransform>
                <ScaleTransform x:Name="MainBadgeScaleTransform"
                                ScaleX="1"
                                ScaleY="1" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="0"
                                  Opacity="0.28"
                                  Color="#000000" />
            </Border.Effect>

            <Border Width="68"
                    Height="68"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#39FF14"
                    BorderBrush="#99000000"
                    BorderThickness="1.5"
                    CornerRadius="34">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Bahnschrift SemiBold"
                           FontSize="24"
                           Foreground="#111111"
                           Text="T-L" />
            </Border>
        </Border>
    </Grid>
</Window>
