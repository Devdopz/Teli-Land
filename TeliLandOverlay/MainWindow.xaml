<Window x:Class="TeliLandOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TeliLand Overlay"
        Width="96"
        Height="96"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit Overlay" Click="ExitOverlay_OnClick" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Background="Transparent">
        <Border Width="82"
                Height="82"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#33FFFFFF"
                BorderBrush="#2A000000"
                BorderThickness="1"
                CornerRadius="41"
                Cursor="Hand"
                MouseLeftButtonDown="Badge_OnMouseLeftButtonDown"
                ToolTip="Drag to move. Right-click to exit.">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="0"
                                  Opacity="0.28"
                                  Color="#000000" />
            </Border.Effect>

            <Border Width="68"
                    Height="68"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#39FF14"
                    BorderBrush="#99000000"
                    BorderThickness="1.5"
                    CornerRadius="34">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Bahnschrift SemiBold"
                           FontSize="24"
                           Foreground="#111111"
                           Text="T-L" />
            </Border>
        </Border>
    </Grid>
</Window>
